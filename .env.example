# URL base da API do backend (sem trailing slash)
EXPO_PUBLIC_API_URL=http://localhost:3000

# URL absoluta do better-auth (geralmente igual à API URL)
EXPO_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Chave pública do Stripe (pk_test_... em dev, pk_live_... em prod)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Posthog — analytics de produto (deixar vazio para desativar em dev)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
