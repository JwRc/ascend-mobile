{
  "cli": {
    "version": ">= 20.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env":{
        "EXPO_PUBLIC_API_URL":"https://app.ascentio.com.br/api",
        "EXPO_PUBLIC_BETTER_AUTH_URL":"https://app.ascentio.com.br/auth"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Release"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
